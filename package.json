{
  "name": "@extrachill/api-client",
  "version": "0.2.0",
  "description": "Universal typed API client for the Extra Chill platform. Works in WordPress blocks, React Native, and Node.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./wordpress": {
      "types": "./dist/wordpress.d.ts",
      "import": "./dist/wordpress.mjs",
      "require": "./dist/wordpress.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "author": "Chris Huber <hello@chubes.net>",
  "license": "GPL-2.0+",
  "repository": {
    "type": "git",
    "url": "https://github.com/Extra-Chill/extrachill-api-client.git"
  },
  "keywords": [
    "extrachill",
    "api",
    "client",
    "wordpress",
    "react-native",
    "typescript"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
